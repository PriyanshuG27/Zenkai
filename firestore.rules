rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // User top-level document
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // sessions subcollection
      match /sessions/{sessionId} {
        allow read, write: if isOwner(uid);
        
        // exercises nested under sessions
        match /exercises/{exerciseId} {
          allow read, write: if isOwner(uid);
        }
      }

      // prs subcollection
      match /prs/{exerciseKey} {
        allow read, write: if isOwner(uid);
      }

      // xpLog subcollection
      match /xpLog/{logId} {
        allow read, write: if isOwner(uid);
      }

      // challengeProgress subcollection
      match /challengeProgress/{challengeId} {
        allow read, write: if isOwner(uid);
      }

      // weeklyPlans subcollection (read-only for client)
      match /weeklyPlans/{weekId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // Challenges: readable by participants, writable by creator or participant
    match /challenges/{challengeId} {
      allow read: if isAuth() &&
        request.auth.uid in resource.data.participants;
      
      allow create: if isAuth();
      
      allow update: if isAuth() && (
        request.auth.uid == resource.data.creatorUid ||
        request.auth.uid in resource.data.participants
      );
      
      allow delete: if false;
    }

    // Rate limits (Cloud Function only)
    match /rateLimits/{docId} {
      allow read, write: if false;
    }
  }
}
