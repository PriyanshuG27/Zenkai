rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────

    // Is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Does the signed-in user own this uid subtree?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Is the signed-in user a participant in this challenge document?
    function isParticipant() {
      return isAuth() && request.auth.uid in resource.data.participants;
    }

    // Is the signed-in user an admin?
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Are the signed-in user and the target user in the same gym?
    function isSameGym(targetUid) {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(targetUid)) &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(targetUid)).data.get('gymId', '') != '' &&
        get(/databases/$(database)/documents/users/$(targetUid)).data.get('gymId', '') == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('gymId', '');
    }

    // ── Field-level validation helpers for users/{uid} ────────────────────────

    // Whitelist of every field written across all phases.
    // Phase 1 (Auth/Onboarding): uid, name, email, userType, onboardingComplete, emailVerified,
    //                             age, gender, heightCm, weightKg, goal, workoutFrequency,
    //                             sessionDuration, dietType, currentSupplements, equipmentList,
    //                             medicalFlags, createdAt
    // Phase 2 (XP/Streak):       xp, level, levelName, streak, streakLastDate, powerUps, badges
    // Phase 5 (Gamification):    cooldowns, skills
    function isValidUserData() {
      // Use diff() to check ONLY the fields being changed in this update,
      // not the entire merged document. Using keys().hasOnly() on the full
      // document would block any update if the user profile contains a legacy
      // or admin-set field (e.g. isAdmin) not in this whitelist.
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        // Identity
        'uid', 'name', 'squadCode',
        // Onboarding
        'userType', 'onboardingComplete', 'onboardingSkipped',
        // Gamification — Phase 2
        'xp', 'cumulativeXP', 'level', 'levelName',
        'streak', 'streakLastDate',
        'powerUps', 'badges', 'xpBoosterUntil',
        // Gamification — Phase 5
        'cooldowns', 'skills',
        // New Profile Fields
        'latestLiftsMap', 'latestRestTimesMap', 'gymId', 'gymName', 'disableRestTimer', 'lookingForSquad', 'totalSessions', 'aura', 'activeTitle',
        // Academic Buffer & Prehab
        'examDeloadActive', 'lastPrehabDate',
        // Plan regeneration limits
        'dailyRegenCount', 'lastRegenDate', 'recentRegenTimes', 'recentGymVerifyTimes',
        // Overdrive Hour verification
        'overdriveVerifiedAt',
        // Metadata
        'createdAt', 'updatedAt',
        // Admin-set fields (written by backend only, but must not block reads of user docs containing them)
        'isAdmin'
      ]);
    }

    function isValidPrivateUserData() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'email', 'emailVerified', 'age', 'gender', 'heightCm', 'weightKg',
        'goal', 'workoutFrequency', 'sessionDuration', 'dietType',
        'currentSupplements', 'equipmentList', 'medicalFlags',
        'examStartDate', 'examEndDate', 'createdAt', 'updatedAt'
      ]);
    }

    // xp must be a non-negative number (prevents XP injection)
    function isValidXP() {
      return !('xp' in request.resource.data) ||
        (request.resource.data.xp is number && request.resource.data.xp >= 0);
    }

    // level must be an integer >= 1
    function isValidLevel() {
      return !('level' in request.resource.data) ||
        (request.resource.data.level is int && request.resource.data.level >= 1);
    }

    // equipmentList max 50 items (schema: max 10 distinct values but allow headroom)
    function isValidEquipmentList() {
      return !('equipmentList' in request.resource.data) ||
        (request.resource.data.equipmentList is list &&
          request.resource.data.equipmentList.size() <= 50);
    }

    // Ensure the client cannot set or modify the isAdmin flag
    function isNotModifyingAdmin() {
      return !('isAdmin' in request.resource.data) ||
        (resource != null && resource.data.get('isAdmin', false) == request.resource.data.get('isAdmin', false)) ||
        (resource == null && request.resource.data.get('isAdmin', false) == false);
    }

    // ─── users/{uid} ─────────────────────────────────────────────────────────

    match /users/{uid} {
      // Any authenticated user can get a specific user profile (prevents scraping since list is restricted)
      allow get: if isAuth();

      // Other authenticated users in the same gym can only read/list profiles via query.
      // We tightly scope this to prevent scraping the entire user database by enforcing:
      // 1. The query must filter by the same gymId.
      // 2. The query must sort by xp.
      // 3. The query must have a strict limit of 20 or less.
      allow list: if isAuth() && 
        resource != null &&
        resource.data != null &&
        resource.data.gymId != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        resource.data.gymId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('gymId', '') &&
        request.query.limit != null &&
        request.query.limit <= 20 &&
        request.query.orderBy != null &&
        request.query.orderBy[0].field == 'xp';

      // Owner creates their own profile (signup — Phase 1)
      allow create: if isOwner(uid) && isValidUserData() && isValidXP() && isValidLevel() && isNotModifyingAdmin();

      // Owner updates, or gym members updating powerUps for streak rescue
      allow update: if (isOwner(uid) && isValidUserData() && isValidXP() && isValidLevel() && isNotModifyingAdmin())
        || (isSameGym(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['powerUps']));


      // Profiles are never deleted from client
      allow delete: if false;

      // Private profile storing PII
      match /private/profile {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && isValidPrivateUserData() && isValidEquipmentList();
      }

      // ── sessions/{sessionId} — Phase 2 ──────────────────────────────────
      // Written atomically in a writeBatch by useWorkoutLogger.
      // Fields: date, dateString, moodTag, stomachFlag, totalVolume,
      //         totalSets, durationMinutes, xpEarned, prCount,
      //         planDayId (Phase 5 plan day reference),
      //         isOverdrive (Phase 5 Overdrive Hour flag),
      //         bestLift (recap cache — { name, weight, isBW, reps? })
      match /sessions/{sessionId} {
        allow read, write: if isOwner(uid);

        // exercises/{exerciseId} — nested sub-collection
        // Fields: exerciseId, name, exerciseKey, muscleGroup, sets[], volume
        match /exercises/{exerciseId} {
          allow read, write: if isOwner(uid);
        }
      }

      // executed_sessions — append-only logged sessions
      match /executed_sessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }

      // planned_targets — target plan schedules
      match /planned_targets/{planId} {
        allow read, write: if isOwner(uid);
      }

      // stalledLifts — plateaued movement diagnostic states
      match /stalledLifts/{exerciseKey} {
        allow read, write: if isOwner(uid);
      }

      // ── prs/{exerciseKey} — Phase 2 ─────────────────────────────────────
      // One document per exercise — stores all-time PR.
      // exerciseKey format validated server-side in firestoreUtils.js.
      match /prs/{exerciseKey} {
        allow read, write: if isOwner(uid);
      }

      // ── weeklyPlans/{weekId} — Phase 3 ──────────────────────────────────
      // Client read and write allowed for the owner (needed for Academic Buffer deload toggles).
      // weekId format: "YYYY-WNN"
      match /weeklyPlans/{weekId} {
        allow read, write: if isOwner(uid);
      }

      // ── xpLog/{entryId} — Phase 2 ────────────────────────────────────────────
      // Append-only audit log.
      // update and delete are NEVER permitted — tamper-proof XP history.
      // Written by useXPEngine.js (client addDoc) and _commitBatch (batch.set).
      // Amount is capped at 500 to prevent clients forging massive XP log entries
      // (the actual user.xp field is still bounded by isValidXP() on the user doc).
      match /xpLog/{entryId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount <= 500;
        // update → implicitly DENIED
        // delete → implicitly DENIED
      }

      // ── challengeProgress/{challengeId} — Phase 5 ───────────────────────
      // Local mirror of challenge progress stored under the user's subtree.
      match /challengeProgress/{challengeId} {
        allow read, write: if isOwner(uid);
      }

      // ── personalTemplates/{templateId} — Phase 5 ────────────────────────
      // Generated by generateChallenge Cloud Function; consumed and deleted
      // by useChallenges.joinChallenge() when user starts a challenge.
      match /personalTemplates/{templateId} {
        allow read, write: if isOwner(uid);
      }

      // ── fcmTokens/{token} — Web Push Notifications ───────────────────────
      // Each document stores a single FCM device token for this user.
      // Multi-device supported: one document per token (token is the doc ID).
      // Delete allowed so stale tokens can be cleaned up on logout.
      match /fcmTokens/{token} {
        allow read, write, delete: if isOwner(uid);
      }
    }

    // ─── squads/{squadId} — Phase 6 ─────────────────────────────────────────────────
    // Read: any auth'd user (needed to join/view squads).
    // Write: only the squad creator (uid field must match auth.uid).
    // Create: auth'd user creating their own squad (uid field validated).
    match /squads/{squadId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // ─── squad_codes/{code} — Phase 6 ──────────────────────────────────────────────
    // Read: any authenticated user (needed for free-agent discovery & leaderboard).
    // Queries must include limit <= 50 to prevent collection dumps.
    // Create: FIX - uid field must equal request.auth.uid to prevent code squatting.
    // Update/delete: only the code owner.
    match /squad_codes/{code} {
      allow get:    if isAuth();
      allow list:   if isAuth() && request.query.limit != null && request.query.limit <= 50;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // ─── squad_invites/{inviteId} — Phase 6 ──────────────────────────────────
    // inviteId format: {squadCode}_{inviteeUid}
    // - read:   invitee OR inviter (checking stored fields)
    // - create: authenticated user who is the inviter (inviterUid == auth.uid)
    // - update: invitee (to accept/decline) OR inviter (to cancel)
    // - delete: inviter only (cancelling a sent invite)
    match /squad_invites/{inviteId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.inviterUid;
      allow update: if isAuth() && (
        request.auth.uid == resource.data.inviteeUid ||
        request.auth.uid == resource.data.inviterUid
      );
      allow delete: if isAuth() && request.auth.uid == resource.data.inviterUid;
    }

    // ─── shared_squads/{squadCode} ────────────────────────────────────────────────────
    // Read: any auth'd user (to see squad data).
    // Write: only the squad root doc owner (creator) or members updating progress/membership.
    // Presence sub-docs: each user only writes their own presence (uid-scoped).
    // Polls: any squad participant.
    match /shared_squads/{squadCode} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.creatorUid == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.creatorUid == request.auth.uid ||
        (
          (request.auth.uid in resource.data.memberUids || request.auth.uid in request.resource.data.memberUids) &&
          request.resource.data.creatorUid == resource.data.creatorUid &&
          request.resource.data.squadName == resource.data.squadName &&
          request.resource.data.memberLimit == resource.data.memberLimit
        )
      );
      allow delete: if isAuth() && resource.data.creatorUid == request.auth.uid;

      // Each user only writes their own presence document
      match /presence/{uid} {
        allow read:  if isAuth() && request.auth.uid in get(/databases/$(database)/documents/shared_squads/$(squadCode)).data.memberUids;
        allow write: if isOwner(uid) && request.auth.uid in get(/databases/$(database)/documents/shared_squads/$(squadCode)).data.memberUids;
      }
      // Activity feed: squad members post summaries, teammates kudos
      match /activity_feed/{activityId} {
        allow read:   if isAuth() && request.auth.uid in get(/databases/$(database)/documents/shared_squads/$(squadCode)).data.memberUids;
        allow create: if isAuth() && request.resource.data.uid == request.auth.uid && request.auth.uid in get(/databases/$(database)/documents/shared_squads/$(squadCode)).data.memberUids;
        allow update: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/shared_squads/$(squadCode)).data.memberUids;
        allow delete: if isAuth() && resource.data.uid == request.auth.uid && request.auth.uid in get(/databases/$(database)/documents/shared_squads/$(squadCode)).data.memberUids;
      }
      // Polls: any squad participant can vote; creator can update/delete
      match /polls/{pollId} {
        allow read:   if isAuth();
        allow create: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/shared_squads/$(squadCode)).data.memberUids;
        allow update: if isAuth() && (
          resource.data.creatorUid == request.auth.uid ||
          (
            request.auth.uid in get(/databases/$(database)/documents/shared_squads/$(squadCode)).data.memberUids &&
            request.resource.data.question == resource.data.question &&
            request.resource.data.options == resource.data.options &&
            request.resource.data.creatorUid == resource.data.creatorUid
          )
        );
        allow delete: if isAuth() && resource.data.creatorUid == request.auth.uid;
      }
    }

    // ─── challenges/{challengeId} — Phase 5 ──────────────────────────────────
    //
    // Types: "comeback" | "streak" | "weak_point"
    // Subtypes: "campaign" | "quest" | "wager"
    //
    // Create: any authenticated user (they create as sole initial participant)
    // Read:   only participants (privacy — other users cannot see your challenges)
    // Update: only participants (progress updates, status: 'abandoned')
    // Delete: DENIED from client — leaveChallenge() uses update status:'abandoned'
    //         The existing fallback in useChallenges.leaveChallenge()
    //         (try deleteDoc → catch → setDoc status:'abandoned') is compatible:
    //         deleteDoc will fail → fallback update succeeds.
    match /challenges/{challengeId} {
      allow read:   if isParticipant();
      allow create: if isAuth();
      allow update: if isParticipant();
      allow delete: if false;
    }

    // ─── rateLimit/{uid} — Phase 3 ───────────────────────────────────────────
    // Written exclusively by the generatePlan Cloud Function via Admin SDK.
    // Collection path MUST match rateLimiter.js: db.doc(`rateLimit/${uid}`)
    // All client access is blocked.
    match /rateLimit/{uid} {
      allow read, write: if false;
    }

    // ─── strengthStandards/{document} ───────────────────────────────────────
    // Populated by the backend route via Admin SDK. Read-only for authenticated users.
    match /strengthStandards/{document} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ─── feedback/{feedbackId} ──────────────────────────────────────────────
    // Allow authenticated users to read and create feedback.
    // Regular users can only update upvotes/downvotes arrays.
    // Admins can read, update (any field), and delete.
    match /feedback/{feedbackId} {
      allow read: if isAuth();
      allow create: if isAuth() && 
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.status == 'Future Plans' &&
        request.resource.data.upvotes.size() == 0 &&
        request.resource.data.downvotes.size() == 0;
        
      allow update: if isAuth() && (
        isAdmin() ||
        (
          request.resource.data.title == resource.data.title &&
          request.resource.data.description == resource.data.description &&
          request.resource.data.category == resource.data.category &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.userName == resource.data.userName &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.get('screenshot', null) == resource.data.get('screenshot', null)
        )
      );
      
      allow delete: if isAdmin();
    }

    // ─── Implicit default deny ────────────────────────────────────────────────
    // Any path not matched above is denied by Firestore's default behaviour.
    // No wildcard catch-all needed — absence of a rule = deny.

  }
}

