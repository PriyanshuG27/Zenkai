# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file with real credentials.

# Firebase Client Config (get from Firebase Console → Project Settings → Your apps)
# These are PUBLIC keys — safe to include in the client bundle.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend API URL (your Express server on Render/Railway/etc.)
# For local dev: http://localhost:10000
# For production: https://your-backend-name.onrender.com  (set this in CI/hosting env vars)
VITE_API_BASE_URL=

# ─── Backend (backend/.env) ───────────────────────────────────────────────────
# These go in backend/.env — NOT this file. Listed here for documentation only.
#
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
#   OR set the JSON content directly as an env var on Render:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# ALLOWED_ORIGINS=https://your-frontend.web.app,https://your-frontend.com
# PORT=10000
# GEMINI_API_KEY=    (if calling Gemini directly from backend)
